# Zhiyin 知音 配置文件示例
# 
# 使用说明：
#   1. 复制此文件为 config.toml：cp config.toml.example config.toml
#   2. 根据你的环境修改配置（本地开发或 Docker）
#   3. config.toml 不会被提交到 Git（已加入 .gitignore）
#
# 配置热重载：
#   - 本地开发：修改后自动重载（需重启服务）
#   - Docker：执行 docker-compose kill -s SIGHUP zhiyin-music

[server]
# 监听地址
# Docker 部署必须使用 "0.0.0.0"（容器网络需要）
# 本地开发建议 "127.0.0.1"（仅本机可访问，更安全）
host = "0.0.0.0"
port = 8080

# 音频流播放后释放文件页缓存（Linux posix_fadvise）
# 大部分客户端会在本地缓存歌曲，服务端页缓存命中率低
# 小内存主机（≤2GB RAM）建议开启，可显著降低内存占用
drop_cache_after_stream = false

[scan]
# 音乐扫描根目录（支持多个路径）
# 
# 本地开发示例：
#   roots = ["/Users/你的用户名/Music", "/Volumes/外置硬盘/Music"]
#
# Docker 部署示例（对应 docker-compose.yml 中的挂载）：
#   roots = ["/music"]
#
roots = ["/music"]

# 扫描模式：manual（手动）/ scheduled（定时）/ watch（监听）
mode = "manual"

# 定时扫描间隔（小时），仅在 scheduled 模式下生效
interval_hours = 24

# 是否跳过过小的音频文件（空文件、损坏文件等）
skip_small_files = true

# 最小文件大小（字节），低于此值的文件将被跳过（默认 1024 = 1KB）
min_file_size = 1024

# ---------- STRM 网盘直链支持 ----------
# 是否扫描 .strm 文件（文件内容为指向远程音频的 URL）
scan_strm = true

# STRM 播放模式：
#   "proxy"    — 服务端代理转发（默认）
#                通过系统 curl 命令跟随重定向链并流式转发音频数据给客户端，
#                不暴露远程 URL；使用 curl -4 强制 IPv4 避免 CDN IPv6 不通问题，
#                兼容国内 CDN（阿里云盘等）的 TLS 要求
#   "redirect" — 智能重定向模式（推荐，节省带宽）
#                启动时自动探测 IPv6 到 CDN 的连通性，每 5 分钟重检：
#                  - IPv6 可达 → 307 重定向给客户端直连，节省服务端带宽
#                  - IPv6 不通 → 自动降级为 proxy 模式，保证播放不中断
#                日志中会显示当前状态切换信息
strm_mode = "redirect"

# 扫描时是否对 strm URL 执行远程探测（HTTP HEAD + ffprobe）获取真实文件大小、时长等属性
# 开启后扫描速度会降低，但歌曲属性更完整；关闭则属性为空，播放时仍可正常工作
strm_probe_remote = false

[database]
# 数据库文件路径
#
# 本地开发示例：
#   path = "./data/db.sqlite"
#
# Docker 部署示例：
#   path = "/data/db.sqlite"
#
path = "/data/db.sqlite"

# 连接池大小
# 低内存主机（≤2GB RAM）建议设为 2，可减少 SQLite 内存开销
pool_size = 4

[covers]
# 封面缓存目录
#
# 本地开发示例：
#   cache_path = "./covers"
#
# Docker 部署示例：
#   cache_path = "/covers"
#
cache_path = "/covers"

# 原图最大边长（像素），入库时超过此值的封面会等比缩放
# 低内存主机建议设为 800，减小封面尺寸以降低内存和存储开销
max_dimension = 1000

# 缩略图编码质量（JPEG 压缩质量，0-100）
quality = 85

# 封面内存缓存（MB），0 表示禁用
# 低内存主机（≤2GB RAM）建议设为 5~10
cache_size_mb = 20

# 封面提取策略优先级：
# 1. embedded: 内嵌在音频文件中的封面
# 2. same_name: 与音频文件同名的图片文件
# 3. standard_names: 使用标准文件名的封面文件

# 标准封面文件名列表（按优先级排序，不区分大小写）
standard_names = [
    "cover",
    "folder",
    "front",
    "album",
    "albumart",
    "albumartsmall"
]

# 支持的图片格式扩展名
image_extensions = ["jpg", "jpeg", "png", "webp"]

[recommend]
# 推荐任务执行间隔（小时）
job_interval_hours = 24

# 触发推荐计算的播放次数阈值
play_threshold = 10

# 推荐结果最大数量
max_results = 50

[transcode]
# 是否启用转码功能
enabled = true

# 转码缓存目录
#
# 本地开发示例：
#   cache_path = "./data/transcoded"
#
# Docker 部署示例：
#   cache_path = "/data/transcoded"
#
cache_path = "/data/transcoded"

# 缓存策略: none（不缓存）、all（缓存所有）、smart（智能缓存）
cache_strategy = "smart"

# 智能缓存阈值（播放次数超过此值的歌曲会被预转码）
cache_threshold = 10

# 最大并发转码任务数
# 低内存主机建议设为 1，减少并发转码的内存占用
max_concurrent_transcodes = 2

[maintenance]
# 是否启用自动数据库维护
enabled = true

# 维护任务执行间隔（小时）
interval_hours = 24

# 播放历史保留天数（0 表示不删除）
history_retention_days = 90

# 推荐缓存保留天数（0 表示不删除）
recommendation_retention_days = 30

# 是否启用增量 VACUUM（碎片清理）
enable_vacuum = true

# VACUUM 触发的碎片率阈值（百分比，0-100）
# 只有当数据库碎片率超过此值时才执行 VACUUM
vacuum_threshold = 30.0

# 推荐策略权重（frequency + recent + similarity，建议合计为 1.0）
[recommend.weights]
frequency = 0.4   # 高频播放策略权重
recent = 0.3      # 最近常听策略权重
similarity = 0.3  # 相似歌曲策略权重

[jobs]
# 后台任务配置

# 任务保留天数（历史任务记录）
retention_days = 30

# 任务清理间隔（小时）
cleanup_interval_hours = 24

[subsonic]
# 是否启用 Subsonic API 兼容层（/rest/ 路径）
enabled = true

# 首次启动时通过环境变量或 /api/setup 创建管理员

[web]
# 是否启用 Web 前端静态文件服务
enabled = true

# 前端构建产物目录
#
# 本地开发示例：
#   path = "./web"
#
# Docker 部署示例：
#   path = "/app/web"
#
path = "/app/web"

[security]
# JWT 密钥（强烈建议设置固定值，否则每次重启服务后所有用户需重新登录）
# 生成方式: openssl rand -hex 32
# jwt_secret = "your-random-hex-secret-here"

# Subsonic 密码加密 Pepper（可选，建议通过环境变量 MUSIC_KEY_PEPPER 注入）
# 未配置时服务会自动生成并持久化到 /data/.zhiyin/key_pepper（默认）
# 如需手动统一密钥，建议长度 >= 32
# 生成方式: openssl rand -hex 32
# 示例（docker-compose.yml）:
#   - MUSIC_KEY_PEPPER=your-random-hex-secret-here

# Token 有效期（小时），默认 168（7 天）
token_expiry_hours = 168

# 兼容保留字段（已废弃）：Subsonic 密码加密不再使用该配置项
# 请改为设置环境变量 MUSIC_KEY_PEPPER
encryption_key = "zhiyin-default-key-CHANGE-ME"

# CORS 允许的来源（空列表或 ["*"] 表示允许所有来源）
# 生产环境建议配置为前端的实际地址
# cors_origins = ["https://music.example.com", "http://localhost:3000"]
cors_origins = []

# 登录限流：窗口期内最大尝试次数（0 表示不限制）
login_rate_limit = 10

# 登录限流窗口期（秒），默认 300 秒（5 分钟）
login_rate_window_secs = 300

# ============================================================
# [scrape] 刮削配置
# ============================================================
[scrape]
# 是否启用刮削功能
enabled = true

# 刮削搜索源（按优先级从高到低排列）
# 可选: netease, qq, kugou, kuwo, migu
sources = ["netease", "qq", "kugou", "kuwo", "migu"]

# 扫描完成后是否自动启动刮削
auto_scrape_after_scan = false

# 搜索到第一个高分匹配后是否停止继续搜索其他源
stop_on_first_match = true

# 自动应用阈值（百分制 0-100）
# 候选匹配分数 >= 此值时自动应用，低于此值需人工审核
# 评分维度：标题相似度(40) + 歌手匹配(30) + 专辑匹配(15) + 元数据完整度(15)
min_score_threshold = 50

# 是否保存歌词为 .lrc 文件（与音频文件同目录）
save_lyrics_file = false

# 是否保存封面图片文件
save_cover_file = false

# HTTP 请求超时（秒）
request_timeout_secs = 10

# 最大并发刮削数
max_concurrent = 3

[logging]
# 日志级别：trace / debug / info / warn / error
level = "info"

# 日志格式：json / pretty
format = "pretty"

# 模块日志级别配置（可选）
# 例如: ["zhiyin=debug", "axum=info", "tower_http=debug"]
modules = []

# ============================================================
# 低内存主机快速参考（≤2GB RAM）
# ============================================================
# 如果在小内存设备（NAS、树莓派等）上运行，建议调整以下配置：
#
#   database.pool_size = 2
#   covers.cache_size_mb = 5
#   covers.max_dimension = 800
#   transcode.max_concurrent_transcodes = 1
#
# 同时在 docker-compose.yml 中设置 mem_limit: 256m（或 192m）
# 限制容器内存上限，内核会自动回收文件页缓存，不会 OOM-kill 进程。

